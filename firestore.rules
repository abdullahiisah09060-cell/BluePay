rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuth() { return request.auth != null; }
    function isAdmin() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; }
    function isOwner(uid) { return request.auth.uid == uid; }

    // User profiles: Only owner or admin can read/write.
    match /users/{uid} {
      allow read: if isAuth() && (isOwner(uid) || isAdmin());
      allow create: if isAuth() && isOwner(uid);
      allow update: if isAuth() && (isOwner(uid) || isAdmin()) && 
                    (request.resource.data.role == resource.data.role); // Prevent self-promotion
    }

    // Transactions: Read-only for users, Admin can manage.
    match /transactions/{id} {
      allow read: if isAuth() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuth(); // Allow programmatic creation
      allow delete, update: if isAdmin();
    }

    // Withdrawals & Deposits: Users create, Admin approves.
    match /withdrawals/{id} {
      allow read: if isAuth() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuth();
      allow update: if isAdmin();
    }

    match /codes/{id} {
      allow read: if isAuth() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuth();
      allow update: if isAuth() && (isOwner(resource.data.uid) || isAdmin());
    }
    
    // Support Threads
    match /support/{uid} {
      allow read, write: if isAuth() && (isOwner(uid) || isAdmin());
      match /messages/{mid} {
        allow read, write: if isAuth();
      }
    }
  }
}
